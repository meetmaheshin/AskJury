DATABASE_URL="postgresql://user:password@localhost:5432/jury_db"
JWT_SECRET="your-secret-key-here-min-32-chars-change-in-production"
PORT=3001
NODE_ENV="development"

CLOUDINARY_CLOUD_NAME="your-cloudinary-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Perplexity API for AI-powered case generation
PERPLEXITY_API_KEY="pplx-xxx"

# Web Push (VAPID) — generate: node -e "console.log(require('web-push').generateVAPIDKeys())"
# Set these in Railway service variables too (push is disabled if unset).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@askjury.com
